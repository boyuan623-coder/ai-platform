{
  "title": "AI Platform Overview",
  "uid": "ai-platform-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Server Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (application)",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Process CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
